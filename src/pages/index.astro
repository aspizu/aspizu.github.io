---
import "@fontsource-variable/figtree"
import "@fontsource-variable/cascadia-code"
import "@/styles/global.css"
// import buttons from "@/content/buttons.json"
import Profile from "@/components/Profile.astro"
import projects from "@/content/projects.json"
import Project from "@/components/Project.astro"
import Analytics from "@vercel/analytics/astro"
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>aspizu</title>
        <link rel="icon" href="/assets/favicon.png" />
        <meta name="description" content="stuff I do" />
        <meta property="og:title" content="aspizu" />
        <meta property="og:description" content="stuff I do" />
        <meta property="og:url" content="https://aspiz.uk/" />
        <meta property="og:site_name" content="aspiz.uk" />
        <meta property="og:image" content="https://aspiz.uk/assets/og/index.png" />
        <meta name="twitter:card" content="summary_large_image" />
        <meta name="twitter:site" content="@aspizu_" />
        <meta name="twitter:title" content="aspizu" />
        <meta name="twitter:description" content="stuff I do" />
        <meta name="twitter:creator" content="@aspizu_" />
        <meta name="twitter:image" content="https://aspiz.uk/assets/og/index.png" />
        <meta name="twitter:image:type" content="image/png" />
        <meta name="twitter:image:alt" content="aspizu" />
        <meta
            name="twitter:image:secure_url"
            content="https://aspiz.uk/assets/og/index.png"
        />
        <meta property="og:image:width" content="1200" />
        <meta property="og:image:height" content="628" />
        <meta property="og:image:alt" content="aspizu" />
        <meta property="og:type" content="website" />
    </head>
    <body class="bg-white text-white scheme-dark">
        <!-- <nav class="my-4 flex justify-center">
            <a
                href="/blog"
                class="flex bg-white text-neutral-700 hover:text-black shadow-lg shadow-white/25 hover:shadow-white/50 items-center gap-1 text-xs transition-all px-2 py-1 rounded-full hover:scale-[1.02]"
            >
                read my blog
                <ArrowUpRight class="size-3.5" />
            </a>
        </nav> -->
        <div
            class="flex flex-col md:flex-row gap-4 items-start justify-center px-6 py-10 max-w-5xl mx-auto"
        >
            <div class="md:sticky md:top-10 shrink-0">
                <Profile />
            </div>
            <div class="grid grid-cols-2 gap-4 flex-1 min-w-0" id="projects">
                {projects.map((project) => <Project {...project} />)}
            </div>
        </div>
        <Analytics />
    </body>
</html>

<script>
    import {GhostCursor} from "@/scripts/ghost-cursor.ts"
    import "@/scripts/hacker-text.ts"
    new GhostCursor()
</script>
